{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentx.dev/schemas/volume-09.schema.json",
  "title": "agentx CLI Platform Schemas",
  "description": "Machine-validatable JSON Schema contracts for Volume 09 - CLI Platform. Covers agentx.config.yaml (represented as JSON Schema).",
  "type": "object",
  "definitions": {
    "CliConfig": {
      "type": "object",
      "required": [
        "defaultProvider",
        "maxParallelAgents",
        "retryCapPerNode",
        "workingDirectory"
      ],
      "properties": {
        "defaultProvider": {
          "type": "string"
        },
        "maxParallelAgents": {
          "type": "integer",
          "minimum": 1
        },
        "retryCapPerNode": {
          "type": "integer",
          "minimum": 0
        },
        "workingDirectory": {
          "type": "string"
        }
      }
    }
  }
}